# Variables d'environnement du backend MediAI Care
# Sur Replit, DATABASE_URL et JWT_SECRET_KEY sont déjà fournis (secrets).

# Connexion PostgreSQL (fournie par Replit en dev)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Clé de signature JWT (générer une valeur aléatoire forte, ne jamais committer)
JWT_SECRET_KEY=change-me-with-a-long-random-value

# Durées de vie des tokens
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Environnement applicatif (development | test | production)
APP_ENV=development
